<Configuration>
  <Networking>Disable</Networking>
  <AudioInput>Disable</AudioInput>
  <VideoInput>Disable</VideoInput>
  <ProtectedClient>Enable</ProtectedClient>
  <ClipboardRedirection>Disable</ClipboardRedirection>
  <PrinterRedirection>Disable</PrinterRedirection>
  <MemoryInMB>8192</MemoryInMB>
  <vGPU>Disable</vGPU>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>C:\Users\<user>\Documents\AgentA\AgentA\workspace</HostFolder>
      <SandboxFolder>C:\agenta\workspace</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
    <MappedFolder>
      <HostFolder>C:\Users\<user>\Documents\AgentA\AgentA\.claude</HostFolder>
      <SandboxFolder>C:\agenta\.claude</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <MappedFolder>
      <HostFolder>C:\Users\<user>\Documents\AgentA\AgentA\bench</HostFolder>
      <SandboxFolder>C:\agenta\bench</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>cmd.exe /c "cd C:\agenta &amp;&amp; start claude --resume-from C:\agenta\workspace\sandbox-bootstrap\current-request.txt"</Command>
  </LogonCommand>
</Configuration>

