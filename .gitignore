.autoresearch-active
.autoresearch-state.md
.claude/settings.local.json
logs/*.jsonl
logs/*.log
# workspace/ scratch is gitignored EXCEPT for task source dirs below.
# Using workspace/* (not workspace/) so git descends into subdirs and the !exceptions apply.
workspace/*
!workspace/example/
!workspace/example-v2/
!workspace/example-perf/
!workspace/example-dead/
!workspace/example-types/
!workspace/example-sec/
!workspace/example-docs/
!workspace/example-cov/
!workspace/example-maint/
# Exclude pycache + pytest cache within tracked subdirs
workspace/example/__pycache__/
workspace/example/**/__pycache__/
workspace/example/.pytest_cache/
workspace/example/**/.pytest_cache/
workspace/example-v2/__pycache__/
workspace/example-v2/**/__pycache__/
workspace/example-v2/.pytest_cache/
workspace/example-v2/**/.pytest_cache/
workspace/example-perf/__pycache__/
workspace/example-perf/**/__pycache__/
workspace/example-perf/.pytest_cache/
workspace/example-perf/**/.pytest_cache/
workspace/example-dead/__pycache__/
workspace/example-dead/**/__pycache__/
workspace/example-dead/.pytest_cache/
workspace/example-dead/**/.pytest_cache/
workspace/example-types/__pycache__/
workspace/example-types/**/__pycache__/
workspace/example-types/.pytest_cache/
workspace/example-types/**/.pytest_cache/
workspace/example-types/.mypy_cache/
workspace/example-types/**/.mypy_cache/
workspace/example-sec/__pycache__/
workspace/example-sec/**/__pycache__/
workspace/example-sec/.pytest_cache/
workspace/example-sec/**/.pytest_cache/
workspace/example-docs/__pycache__/
workspace/example-docs/**/__pycache__/
workspace/example-docs/.pytest_cache/
workspace/example-docs/**/.pytest_cache/
workspace/example-cov/__pycache__/
workspace/example-cov/**/__pycache__/
workspace/example-cov/.pytest_cache/
workspace/example-cov/**/.pytest_cache/
workspace/example-cov/.coverage
workspace/example-cov/**/.coverage
workspace/example-maint/__pycache__/
workspace/example-maint/**/__pycache__/
workspace/example-maint/.pytest_cache/
workspace/example-maint/**/.pytest_cache/
*.vhdx
holdout/
!holdout/.gitkeep
*.lock
__pycache__/
.pytest_cache/
node_modules/
.env
.env.local
*.tmp

# host patch backups (out-of-band SYSTEM applies)
host/**/*.bak-*
workspace/fixes/*.log
workspace/fixes/_*
